{
  "enabled": false,
  "name": "Appian Deployment API Docs",
  "description": "When a prompt is submitted, loads the Appian Deployment REST API reference (all 8 endpoints) as context for deployment-related questions and tasks.",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Load the Appian Deployment REST API reference from the steering file .kiro/steering/appian-deployment-api.md and use it as context. This covers all 8 API endpoints: Overview (https://docs.appian.com/suite/help/26.3/Deployment_Rest_API.html), Application Package Details (https://docs.appian.com/suite/help/26.3/Application_Package_Details_API.html), Export Package (https://docs.appian.com/suite/help/26.3/Export_Package_API.html), Inspect Package (https://docs.appian.com/suite/help/26.3/Inspect_Package_API.html), Get Inspection Results (https://docs.appian.com/suite/help/26.3/Get_Inspection_Results_API.html), Deploy Package (https://docs.appian.com/suite/help/26.3/Deploy_Package_API.html), Get Deployment Results (https://docs.appian.com/suite/help/26.3/Get_Deployment_Results_API.html), Get Deployment Log (https://docs.appian.com/suite/help/26.3/Get_Deployment_Log_API.html). Base URL: https://<domain>/suite/deployment-management/v2. Auth: API key or OAuth 2.0 Bearer token."
  }
}